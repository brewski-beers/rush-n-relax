# ============================================
# ENVIRONMENT VARIABLES — copy to .env.local
# ============================================
# DO NOT commit .env.local — it is gitignored.
# This file documents all required keys.

# ============================================
# GOOGLE MAPS (REQUIRED FOR LOCATION PAGES)
# ============================================
# Google Cloud Console → APIs & Services → Credentials
# Enable: Maps Embed API, Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================
# FIREBASE ADMIN SDK — LOCAL DEV EMULATORS
# ============================================
# Routes Admin SDK calls to local emulators.
# Both vars are read natively by the Admin SDK — no code changes needed.
# Remove these lines to point at production Firebase (requires ADC or service account).
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# ============================================
# FIREBASE ADMIN SDK — PRODUCTION / CI
# ============================================
# Option A: Path to a gitignored service account JSON (local dev against prod)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Option B: Full service account JSON as a string (CI environments)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# In Firebase App Hosting (production): neither is needed.
# Application Default Credentials are provided automatically.

# ============================================
# AGECHECKER — TEST MODE STRATEGY (per env)
# ============================================
# Local dev + Playwright CI: BOTH `true` → simulate modal, no AC network calls.
# Vercel Preview: BOTH `false` → real AgeChecker Test Mode (dashboard toggle ON
#   for the preview hostname; merchant is not billed for test verifications).
# Vercel Production: BOTH `false` (or unset) → live AgeChecker.
# The `NEXT_PUBLIC_` var gates the client-side simulate UI; the unprefixed var
# gates the server-side webhook handler. They MUST stay in sync per environment.
NEXT_PUBLIC_AGECHECKER_TEST_MODE=true
AGECHECKER_TEST_MODE=true
