{
  "name": "web",
  "version": "1.0.0",
  "description": "Rush N Relax storefront + admin (Next.js 15)",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check-docs": "node ../../tools/check-docs.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm check-docs && pnpm typecheck && next lint",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "lint:fix": "next lint --fix",
    "test": "vitest --run",
    "test:unit": "vitest --run",
    "test:unit:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "TEST_MODE=smoke playwright test e2e/age-gate.spec.ts --reporter=line",
    "test:e2e:smoke:prod": "TEST_MODE=smoke PLAYWRIGHT_BASE_URL=https://rushnrelax.com playwright test e2e/age-gate.spec.ts --reporter=line",
    "test:e2e:core": "TEST_MODE=core playwright test e2e/age-gate.spec.ts e2e/user-journey.spec.ts e2e/app.spec.ts e2e/reviews.spec.ts e2e/admin-login.spec.ts --reporter=line",
    "test:e2e:full": "TEST_MODE=full playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:health": "playwright test e2e/health-checks.spec.ts",
    "functions:shell": "firebase functions:shell",
    "functions:logs": "firebase functions:log"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@vercel/analytics": "^2.0.1",
    "firebase": "^10.7.1",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^14.23.0",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "8.59.1",
    "vite": "^5.0.11",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  }
}
