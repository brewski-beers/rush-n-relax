# ============================================
# ENVIRONMENT VARIABLES — copy to .env.local
# ============================================
# DO NOT commit .env.local — it is gitignored.
# This file documents all required keys.

# ============================================
# GOOGLE MAPS (REQUIRED FOR LOCATION PAGES)
# ============================================
# Google Cloud Console → APIs & Services → Credentials
# Enable: Maps Embed API, Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================
# FIREBASE ADMIN SDK — LOCAL DEV EMULATORS
# ============================================
# Routes Admin SDK calls to local emulators.
# Both vars are read natively by the Admin SDK — no code changes needed.
# Remove these lines to point at production Firebase (requires ADC or service account).
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# ============================================
# FIREBASE ADMIN SDK — PRODUCTION / CI
# ============================================
# Option A: Path to a service account JSON stored OUTSIDE the repo (e.g. ~/.secrets, chmod 600).
# Never place a key inside the repo tree, even if gitignored.
# GOOGLE_APPLICATION_CREDENTIALS=$HOME/.secrets/rush-n-relax-sa.json

# Option B: Full service account JSON as a string (CI environments + Vercel)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Production runtime uses Option B via Vercel's encrypted env var on the
# vercel-runtime SA. See `firebase-deploy-iam.md` in the Obsidian vault.

# ============================================
# SITE URL
# ============================================
# Absolute base URL for server-built links (AgeChecker callback_url, etc.).
# Production: https://rushnrelax.com. Preview falls back to https://${VERCEL_URL}.
# SITE_URL=https://rushnrelax.com
# NEXT_PUBLIC_SITE_URL=https://rushnrelax.com

# ============================================
# AGECHECKER.NET — age verification
# ============================================
# Dashboard: https://agechecker.net  (Install tab → keys + Dev Mode + domain allowlist)
#   AGECHECKER_API_KEY              — domain API key  (`key` body field / X-AgeChecker-Key header)
#   AGECHECKER_SECRET               — account secret  (`secret` body field / X-AgeChecker-Secret;
#                                     also the HMAC-SHA1 key for inbound callback signatures). Distinct from the domain key.
#   NEXT_PUBLIC_AGECHECKER_API_KEY  — public site key the browser popup config consumes.
#   AGECHECKER_API_BASE             — optional; defaults to https://api.agechecker.net
# AGECHECKER_API_KEY=
# AGECHECKER_SECRET=
# NEXT_PUBLIC_AGECHECKER_API_KEY=
#
# AGECHECKER_TEST_MODE — local dev / CI only. When `true`: createAgeCheckerSession
# returns a `test-session-*` stub, verifyVerificationId short-circuits `test-verify-*`,
# and inbound callbacks are accepted unsigned — all without a network call. MUST be
# unset (or not `true`) in Production. (Preview/Production also auto-render a simulate
# panel when VERCEL_ENV !== 'production' — that's server-decided, not an env var.)
AGECHECKER_TEST_MODE=true

# ============================================
# CLOVER eCOMM HOSTED CHECKOUT — payments
# ============================================
# CLOVER_LIVE_PAYMENTS_ENABLED — the kill switch. Anything other than the exact
#   string `true` ⇒ the Clover bridge stubs out (no real charges, every order
#   tagged testMode). Set to `true` on Vercel Preview (against the sandbox merchant)
#   and Production (against the live merchant). Leave UNSET for local dev.
# CLOVER_MERCHANT_ID — merchant id (sandbox merchant on Preview, live on Production).
# CLOVER_API_KEY     — merchant private API token.
# CLOVER_BASE_URL    — optional; defaults to https://api.clover.com. Point at the
#   Clover sandbox base for Preview.
# CLOVER_LIVE_PAYMENTS_ENABLED=
# CLOVER_MERCHANT_ID=
# CLOVER_API_KEY=
# CLOVER_BASE_URL=

# ============================================
# CHECKOUT (optional tuning)
# ============================================
# CHECKOUT_REDIRECT_TIMEOUT_MS — how long GET /api/checkout/[sessionId]/redirect
#   polls Firestore for ageVerifiedAt before handing the customer the
#   /checkout/awaiting holding page. Default 5000.
# CHECKOUT_REDIRECT_TIMEOUT_MS=5000
