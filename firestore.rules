rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Contact submissions collection: server-side only via Admin SDK endpoint
    match /contact-submissions/{docId} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    // Email template + queue collections are server-only
    match /email-templates/{docId} {
      allow read, write: if false;
    }

    match /email-template-revisions/{docId} {
      allow read, write: if false;
    }

    match /outbound-emails/{docId} {
      allow read, write: if false;
    }

    // Location reviews: written daily by scheduled Cloud Function (Admin SDK bypasses rules)
    // Clients read directly; writes remain server-only
    match /location-reviews/{placeId} {
      allow read: if true;
      allow write: if false;
    }

    // Core data collections: server-side only via Admin SDK (Next.js Server Components)
    // No client access needed — all reads go through the server
    match /locations/{docId} {
      allow read, write: if false;
    }
    match /products/{docId} {
      allow read, write: if false;
    }
    match /product-categories/{docId} {
      allow read, write: if false;
    }
    match /promos/{docId} {
      allow read, write: if false;
    }
    // inventory/online — storefront reads allowed for pricing resolution.
    // All other locations and all writes remain server-only.
    match /inventory/online/items/{productId} {
      allow read: if true;
      allow write: if false;
    }
    match /inventory/{locationId}/items/{productId} {
      allow read, write: if false;
    }

    // Variant templates: server-side only via Admin SDK
    match /variant-templates/{docId} {
      allow read, write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}