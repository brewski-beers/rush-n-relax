{
  "name": "rush-n-relax",
  "version": "1.0.0",
  "description": "Cannabis retail PWA with Firestore backend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulators": "firebase emulators:start",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:emulators\"",
    "build": "tsc && vite build",
    "build:analyze": "npm run build && open dist/stats.html",
    "build:functions": "cd functions && npm run build",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "seed:categories": "tsx scripts/seed-categories.ts",
    "seed:products": "tsx scripts/seed-products.ts",
    "functions:shell": "firebase functions:shell",
    "functions:logs": "firebase functions:log"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.19",
    "dotenv": "^17.2.3",
    "firebase": "^10.7.1",
    "firebaseui": "^6.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-error-boundary": "^6.1.0",
    "react-lazy-load-image-component": "^1.6.3",
    "react-router-dom": "^7.12.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@playwright/test": "^1.57.0",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/react-lazy-load-image-component": "^1.6.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/ui": "^1.1.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "firebase-admin": "^13.0.1",
    "firebase-tools": "^13.0.2",
    "jsdom": "^23.0.1",
    "prettier": "^3.1.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.1.0"
  }
}
