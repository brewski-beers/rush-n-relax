{
  "name": "rush-n-relax-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Rush N Relax monorepo — storefront, staff (future), kiosk (future)",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "turbo run dev --filter=web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:core": "pnpm --filter web test:e2e:core",
    "test:e2e:smoke": "pnpm --filter web test:e2e:smoke",
    "test:e2e:smoke:prod": "pnpm --filter web test:e2e:smoke:prod",
    "test:e2e:full": "pnpm --filter web test:e2e:full",
    "test:health": "pnpm --filter web test:health",
    "dev:emulators": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data --project=rush-n-relax",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:emulators\"",
    "dev:seed": "tsx tools/seed-emulators.ts && tsx tools/seed-vendors.ts && tsx tools/seed-catalog.ts",
    "emulator:export": "firebase emulators:export ./emulator-data --project=rush-n-relax",
    "seed:prod:content": "tsx tools/prod-upsert-content.ts",
    "migrate:products:docids": "tsx tools/migrate-product-doc-ids.ts",
    "build:functions": "cd functions && npm run build",
    "check-docs": "node tools/check-docs.cjs",
    "lint:styles": "pnpm --filter web lint:styles",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\"",
    "prepare": "[ -n \"$CI\" ] || { command -v husky >/dev/null 2>&1 && husky; } || true",
    "seed:email-templates:orders": "tsx tools/seed-order-email-templates.ts"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --config apps/web/eslint.config.js --fix --no-warn-ignored",
      "prettier --write"
    ],
    "apps/web/src/**/*.css": [
      "stylelint --config apps/web/stylelint.config.cjs --allow-empty-input",
      "prettier --write"
    ],
    "*.{ts,tsx,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "firebase-tools": "^14.23.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.1.1",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.3.3"
  }
}
