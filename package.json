{
  "name": "rush-n-relax",
  "version": "1.0.0",
  "description": "Cannabis retail PWA with Firestore backend",
  "scripts": {
    "dev": "next dev",
    "dev:emulators": "firebase emulators:start",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:emulators\"",
    "dev:seed": "npx tsx scripts/seed-emulators.ts",
    "seed:prod:content": "npx tsx scripts/prod-upsert-content.ts",
    "migrate:products:docids": "npx tsx scripts/migrate-product-doc-ids.ts",
    "build": "next build",
    "build:functions": "cd functions && npm run build",
    "start": "next start",
    "check-docs": "node scripts/check-docs.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "npm run check-docs && npm run typecheck && next lint",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\"",
    "test": "vitest --run",
    "test:unit": "vitest --run",
    "test:unit:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "concurrently --kill-others-on-fail \"npm run dev:all\" \"wait-on http://localhost:3000 tcp:localhost:8080 && npm run test:e2e\"",
    "test:e2e:smoke": "TEST_MODE=smoke playwright test e2e/age-gate.spec.ts --reporter=line",
    "test:e2e:smoke:prod": "TEST_MODE=smoke PLAYWRIGHT_BASE_URL=https://rushnrelax.com playwright test e2e/age-gate.spec.ts --reporter=line",
    "test:e2e:core": "TEST_MODE=core playwright test e2e/age-gate.spec.ts e2e/user-journey.spec.ts e2e/app.spec.ts e2e/reviews.spec.ts --reporter=line",
    "test:e2e:full": "TEST_MODE=full playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:health": "playwright test e2e/health-checks.spec.ts",
    "functions:shell": "firebase functions:shell",
    "functions:logs": "firebase functions:log",
    "prepare": "[ -n \"$CI\" ] || { command -v husky >/dev/null 2>&1 && husky; } || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --allow-empty-input",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "firebase": "^10.7.1",
    "next": "^15.3.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.3.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^14.23.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.1.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.0.11",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  }
}
